{
  "name": "koa3-cli",
  "version": "1.0.9",
  "description": "Koa3脚手架",
  "main": "app.js",
  "bin": {
    "koa3-cli": "bin/cli.js"
  },
  "preferGlobal": true,
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:adminclient\"",
    "dev:server": "nodemon app.js",
    "dev:adminclient": "npm --prefix client run dev",
    "package:release": "powershell -ExecutionPolicy Bypass -File scripts/package-release.ps1",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "koa3",
    "scaffold",
    "cli"
  ],
  "author": "hikerw <965366906@qq.com>",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/wangziwl/koa3-cli"
  },
  "homepage": "https://atwzc.cn/",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.6.0",
    "@ladjs/koa-views": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "ejs": "^4.0.1",
    "formidable": "^3.5.4",
    "joi": "^17.13.4",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.2.1",
    "koa-bodyparser": "^4.4.1",
    "koa-static": "^5.0.0",
    "mongoose": "^8.24.0",
    "qiniu": "^7.15.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  },
  "volta": {
    "node": "20.18.1"
  }
}
