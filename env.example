# 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# 运行环境: development, production, test
NODE_ENV=development

# 服务端口
PORT=3000

# 应用密钥（多个密钥用逗号分隔）
KEYS=your-secret-key-1,your-secret-key-2

# 跨域配置
# 默认关闭跨域；如果前端和接口不在同一域名下，可设置为 true 并限制允许来源。
CORS_ENABLE=false
CORS_ORIGIN=*

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=test

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

LOG_DIR=logs
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
